#!/usr/bin/with-contenv bash
# shellcheck shell=bash
#
# s6 oneshot — fix /config ownership after a PUID/PGID change.
#
# The LSIO base image's init-adduser remaps user `abc` to the operator's
# PUID/PGID but only shallow-chowns /config (non-recursive). Files created
# under a previous uid (e.g. narratorr.db owned 911:911 from the default abc)
# stay stranded, so the newly-remapped app user can read (0644) but not write
# them and every DB write fails with SQLITE_READONLY. Recursively chown /config
# to `abc` so writes succeed after the operator changes PUID/PGID.
#
# Ordering (load-bearing): runs after init-adduser (PUID/PGID already applied to
# `abc`) and before svc-narratorr (Node opens the DB) — wired via dependencies.d.
#
# Scope (load-bearing): /config ONLY. Never the media mount volumes — the app
# does not own that data and a recursive chown over a large library / NFS share
# on every boot is expensive. /config is a DB + logs, so -R there is free.
#
# Graceful (matches LSIO behavior): if the chown fails (e.g. /config on a
# root-squashed NFS export), warn to the container log and still boot. A
# stranded-but-readable DB with a clear warning beats a container that refuses
# to start. Do NOT exit non-zero here — that would abort the s6-rc bring-up.

lsiown -R abc:abc /config \
  || echo "[init-narratorr-config] WARNING: could not chown /config; DB writes may fail if ownership is wrong"
