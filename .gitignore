# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/

# Codex symlink (resolves to .claude/ — don't track as separate dir)
.agents/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude auto-memory (belongs in ~/.claude/projects/, not repo)
memory/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/
lighthouse-reports/
.lighthouseci/
.lighthouserc.json

# Playwright E2E
e2e/test-results/
e2e/playwright-report/
e2e/.run-state.json

# Turbo
.turbo/

# Database
*.db
*.db-journal

# Config directory (for local development)
config/

# Temp files
tmp/
temp/

# Claude Code — ignore everything except skills, docs, templates, and settings
.claude/*
!.claude/skills/
!.claude/docs/
!.claude/templates/
!.claude/settings.json

# CL scratch is ephemeral — deleted by /handoff
.narratorr/cl/scratch.md

# Generated metrics output
.narratorr/workflow-stats.md

# Stop hook runtime state (marker files)
.narratorr/state/
