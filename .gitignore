# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/

# Codex symlink (resolves to .claude/ — don't track as separate dir)
.agents/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude auto-memory (belongs in ~/.claude/projects/, not repo)
memory/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/
lighthouse-reports/
.lighthouseci/
.lighthouserc.json

# Playwright E2E
e2e/test-results/
e2e/playwright-report/

# Turbo
.turbo/

# Database
*.db
*.db-journal

# Config directory (for local development)
config/

# Temp files
tmp/
temp/

# Claude Code — ignore everything except docs, templates, settings, and whitelisted skills
.claude/*
!.claude/docs/
!.claude/templates/
!.claude/settings.json
!.claude/skills/
# Skills: ignore everything by default; add `!.claude/skills/<name>/` lines to ship specific skills
.claude/skills/*

# CL scratch is ephemeral
.narratorr/cl/scratch.md
