{
  "name": "narratorr",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "author": "Todd Johnson",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:server": "tsup",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "verify": "pnpm lint && pnpm test && pnpm typecheck && pnpm build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "docker:build": "docker build -t narratorr .",
    "docker:up": "docker compose up -d"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.3",
    "@tanstack/react-query": "^5.100.6",
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "dompurify": "^3.4.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "fuse.js": "^7.3.0",
    "music-metadata": "^11.12.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "socks-proxy-agent": "^10.0.0",
    "sonner": "^2.0.7",
    "undici": "^8.1.0",
    "unzipper": "^0.12.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "msw": "^2.14.2",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0",
      "minimatch@>=9.0.0 <9.0.9": "9.0.9",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "ajv@>=7.0.0 <8.18.0": "8.18.0",
      "file-type@>=13.0.0 <21.3.2": "21.3.2",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "brace-expansion@>=1.0.0 <1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5"
    }
  }
}
