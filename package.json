{
  "name": "narratorr",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "author": "Todd Johnson",
  "type": "module",
  "scripts": {
    "gitea": "node scripts/gitea.ts",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:server": "tsup",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "docker:build": "docker build -t narratorr .",
    "docker:up": "docker compose up -d",
    "lighthouse": "node --import tsx e2e/lighthouse/run.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.14.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "fuse.js": "^7.1.0",
    "music-metadata": "^11.12.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "socks-proxy-agent": "^8.0.5",
    "sonner": "^2.0.7",
    "undici": "^7.22.0",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-zod": "^0.8.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.9": "9.0.9",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "ajv@>=7.0.0 <8.18.0": "8.18.0",
      "file-type@>=13.0.0 <21.3.1": "21.3.1"
    }
  }
}
