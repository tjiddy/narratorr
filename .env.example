# Narratorr environment variables — copy to .env and edit.
# All variables are optional unless noted. .env is gitignored; this file is the public template.

# Server
# PORT=3000
# NODE_ENV=production
# CORS_ORIGIN=http://localhost:5173

# Storage
# CONFIG_PATH=./config
# DATABASE_URL=./config/narratorr.db

# URL prefix when running behind a path-prefixed reverse proxy (e.g. https://host/narratorr)
# URL_BASE=/

# Encryption key for credential storage (32+ random bytes, base64).
# Auto-generated to <CONFIG_PATH>/secret.key on first run if unset.
# NARRATORR_SECRET_KEY=

# Auth bypass — DEV ONLY. Skips all auth checks; never set in production.
# AUTH_BYPASS=false

# Background poll cadence (cron). Default 30s.
# MONITOR_INTERVAL_CRON=*/30 * * * * *

# Reverse-proxy trust list. REQUIRED whenever Narratorr sits behind any proxy AND
# local-network bypass is enabled in settings — without it, request.ip resolves to
# the proxy IP, every external request looks local, the bypass triggers for the
# entire internet, and per-IP rate limits collapse into one shared bucket.
#
# Comma-separated list of IPs / CIDRs / proxy-addr keywords (loopback, linklocal,
# uniquelocal). Unset = X-Forwarded-For is ignored (default; safe only for
# direct-exposure deploys with no proxy in front).
#
# CRITICAL: list EVERY proxy in the chain. @fastify/proxy-addr walks X-Forwarded-For
# right-to-left and returns the first address NOT in the trust list — if an
# intermediate hop is untrusted, request.ip falls back to that hop. In a Docker /
# private-subnet deploy that hop is itself private and re-enables the bypass for
# external clients. Trust the entire chain or none of it.
#
# TRUSTED_PROXIES=10.0.0.0/8
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12
# TRUSTED_PROXIES=loopback
